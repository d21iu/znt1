# 复制为 .env 后按本机实际服务修改
AI_ENABLED=true

# ---------- 方案 A：Ollama 本地 Qwen（默认）----------
# 先执行: ollama pull qwen2.5:7b
# 图片/视频需视觉模型: ollama pull qwen2.5vl:7b
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:7b
OPENAI_VISION_MODEL=qwen2.5vl:7b

# ---------- 方案 B：vLLM / Xinference 等 ----------
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_MODEL=Qwen2.5-7B-Instruct
# OPENAI_VISION_MODEL=Qwen2.5-VL-7B-Instruct

# 也可用 QWEN_* 别名（与 OPENAI_* 二选一即可）
# QWEN_BASE_URL=http://127.0.0.1:11434/v1
# QWEN_MODEL=qwen2.5:7b
# QWEN_VISION_MODEL=qwen2.5vl:7b

AI_TIMEOUT=180
